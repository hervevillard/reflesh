# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# HuggingFace token — required only for Docker.
# Get yours at https://huggingface.co/settings/tokens (read access is enough)
# For local use (launch.bat / python main.py), run `huggingface-cli login` instead.
HF_TOKEN=hf_your_token_here

# Suppress the HuggingFace symlinks warning on Windows.
# Windows requires Developer Mode or admin rights for symlinks; the cache still
# works correctly without them (it just copies files instead of symlinking).
HF_HUB_DISABLE_SYMLINKS_WARNING=1
